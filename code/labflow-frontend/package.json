{
	"name": "labflow-frontend",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=20.19.0 <23"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"postinstall": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"deploy": "gh-pages -d build",
		"sonar": "sonar-scanner -Dsonar.host.url=https://sonarcloud.io -Dsonar.token= -Dsonar.projectKey=NathanNeve_LabFlowFrontend -Dsonar.organization=nathanneve -Dsonar.sources=src"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/eslint": "^9.6.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"gh-pages": "^6.1.1",
		"globals": "^15.0.0",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"sonar-scanner": "^3.1.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.13",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^7.2.2"
	},
	"dependencies": {
		"autoprefixer": "^10.4.20",
		"dotenv": "^16.4.7",
		"dotenv-cli": "^8.0.0",
		"jsprintmanager": "^7.0.2",
		"jwt-decode": "^4.0.0",
		"postcss": "^8.4.47",
		"svelte-awesome-color-picker": "4.1.0",
		"svelte-icons": "^2.1.0",
		"svelte-multiselect": "^11.3.0",
		"svelte-preprocess": "^6.0.3"
	}
}
